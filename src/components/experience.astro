---
<section id="experience" class="w-full py-12 border-t border-[#ffffff10]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">
      Chambeando
    </h2>
    <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-6">
      Experiencia
    </h3>
    <div class="mt-10 lg:ml-10">
      <ol class="group/list space-y-12">
        {EXPERIENCE.map((experience) => <XpCards {...experience} />)}
      </ol>
    </div>

  </div>
</section>
